{
  "name": "guideme-functions",
  "version": "1.0.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test lib/logging/GuideMeLogger.test.js lib/attractionCuration.test.js",
    "smoke:gemini": "npm run build && node lib/scripts/smokeGemini.js",
    "smoke:gemini:cache": "npm run build --cache ./.npm-cache && node lib/scripts/smokeGemini.js",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions,firestore,storage"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^5.6.0",
    "@google-cloud/translate": "^8.5.0",
    "@google/generative-ai": "^0.21.0",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
