rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /guide-audio/{poiId}/{languageCode}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /offline-packs/{tripId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
